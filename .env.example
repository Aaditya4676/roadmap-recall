# Reminders and encrypted weekly backups
RESEND_API_KEY=
RESEND_FROM=Roadmap Recall <reminders@example.com>
CRON_SECRET=
# Base64-encoded 32-byte AES key. Keep it outside the database.
BACKUP_ENCRYPTION_KEY=
